{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "笑褨谢褜",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#construct"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ccil",
          "match": "\\b(写褨褟|褟泻|褑褨谢褜|屑械褌邪|胁懈写邪谢懈褌懈|蟹屑褨薪薪邪|泻芯屑锌芯蟹懈褑褨褟|褋械泻褑褨褟|胁谢邪褋褌懈胁褨褋褌褜|褋锌械褑|褟|褉芯蟹褕懈褉懈褌懈|蟹芯胁薪褨褕薪褟|胁薪褍褌褉褨褕薪褟|屑褨褋褑械胁邪|锌芯泻谢邪褋褌懈|胁褨写泻谢邪褋褌懈|褋褌褉褍泻褌褍褉邪|锌械褉械斜褉邪褌懈|褟泻褖芯|褔械泻邪褌懈|胁蟹褟褌懈|胁械褉薪褍褌懈|褨薪邪泻褕械|斜褨斜|锌芯泻懈)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ccil",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ccil",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.ccil",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.ccil",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ccil",
          "begin": "/\\*.*",
          "end": "\\*/"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.ccil",
          "match": "\\b(褌械泻褋褌|锌邪屑始褟褌褜|泻芯屑褨褉泻邪|谢芯谐褨褔薪械|褑8|褑16|褑32|褑64|褑褨谢械|写32|写褨泄褋薪械|锌8|锌16|褋褨|锌32|锌64|锌芯蟹懈褌懈胁薪械|褋锌懈褋芯泻|褖芯褋褜|薪褨褖芯|褌邪泻|薪褨|锌褍褋褌芯)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.ccil",
          "match": "\\b(\\w+'?\\w+)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "begin": "([::|\\w]+)(<[::|\\w]+>)?\\(",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.ccil"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#comments"
            },
            {
              "include": "#types"
            },
            {
              "include": "#functions"
            },
            {
              "include": "#variables"
            }
          ],
          "end": "\\)"
        }
      ]
    },
    "construct": {
      "patterns": [
        {
          "begin": "([::|\\w]+)(<[::|\\w]+>)? \\{",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.ccil"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#comments"
            },
            {
              "include": "#types"
            },
            {
              "include": "#functions"
            },
            {
              "include": "#variables"
            }
          ],
          "end": "[ |\\n|\\}]"
        }
      ]
    }
  },
  "scopeName": "source.褑褨谢褜"
}
