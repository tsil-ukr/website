{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "笑褨谢褜",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#construct"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ccil",
          "match": "\\b(写褨褟|械泻褋褌械褉薪|褑褨谢褜|屑械褌邪|胁懈写邪谢懈褌懈|蟹斜械褉械谐褌懈|胁褨写泻谢邪褋褌懈|褋褌褉褍泻褌褍褉邪|锌械褉械斜褉邪褌懈|褟泻褖芯|褔械泻邪褌懈|胁蟹褟褌懈|胁械褉薪褍褌懈|褨薪邪泻褕械|斜褨斜|褋褌胁芯褉懈褌懈|锌芯泻懈)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ccil",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ccil",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.ccil",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.ccil",
          "match": ";;.*$"
        },
        {
          "name": "comment.block.ccil",
          "begin": ";\\-\\-.*",
          "end": "\\-\\-;"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.ccil",
          "match": "\\b(褌械泻褋褌|锌邪屑始褟褌褜|褑8|泻芯屑褨褉泻邪|谢芯谐褨褔薪械|褑32|褑64|写32|写64|褋锌懈褋芯泻|褖芯褋褜|薪褨褖芯|褌邪泻|薪褨|锌褍褋褌芯)\\b"
        },
        {
          "comment": "薪邪蟹胁邪 褋褌褉褍泻褌褍褉懈",
          "name": "support.type.struct.ccil",
          "match": "(?<=褋褌褉褍泻褌褍褉邪\\s)\\b(\\w+'?\\w+)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "胁懈泻谢懈泻 褎褍薪泻褑褨褩",
          "begin": "(\\w+)\\(",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.ccil"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#comments"
            },
            {
              "include": "#types"
            },
            {
              "include": "#functions"
            },
            {
              "include": "#variables"
            }
          ],
          "end": "\\)"
        }
      ]
    },
    "construct": {
      "patterns": [
        {
          "comment": "褋褌胁芯褉械薪薪褟 褋褌褉褍泻褌褍褉懈",
          "begin": "(\\w+)(::(褋褌胁芯褉懈褌懈))?{",
          "beginCaptures": {
            "1": {
              "name": "entity.name.class.ccil"
            },
            "3": {
              "name": "keyword.control.ccil"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#comments"
            }
          ],
          "end": "}"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "comment": "蟹屑褨薪薪邪",
          "name": "variable.other.ccil",
          "match": "\\b(\\w+'?\\w+)\\b"
        }
      ]
    }
  },
  "scopeName": "source.褑褨谢褜"
}
