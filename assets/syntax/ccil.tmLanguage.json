{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "–¶—Ц–ї—М",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#construct"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ccil",
          "match": "\\b(–і—Ц—П|—Ж—Ц–ї—М|–Љ–µ—В–∞|—Б—В—А—Г–Ї—В—Г—А–∞|–њ–µ—А–µ–±—А–∞—В–Є|—П–Ї—Й–Њ|—З–µ–Ї–∞—В–Є|–≤–Ј—П—В–Є|–≤–µ—А–љ—Г—В–Є|—Ц–љ–∞–Ї—И–µ|–Ї—Ц–љ–µ—Ж—М|–њ–Њ–Ї–Є)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ccil",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ccil",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.ccil",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.ccil",
          "match": ";;.*$"
        },
        {
          "name": "comment.block.ccil",
          "begin": ";\\-\\-.*",
          "end": "\\-\\-;"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.ccil",
          "match": "\\b(—В–µ–Ї—Б—В|–ї–Њ–≥—Ц—З–љ–µ|—Ж32|—Ж64|–і32|–і64|—Б–њ–Є—Б–Њ–Ї|—Й–Њ—Б—М|–љ—Ц—Й–Њ|—В–∞–Ї|–љ—Ц|–њ—Г—Б—В–Њ)\\b"
        },
        {
          "comment": "–љ–∞–Ј–≤–∞ —Б—В—А—Г–Ї—В—Г—А–Є",
          "name": "support.type.struct.ccil",
          "match": "(?<=—Б—В—А—Г–Ї—В—Г—А–∞\\s)\\b(\\w+'?\\w+)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "–≤–Є–Ї–ї–Є–Ї —Д—Г–љ–Ї—Ж—Ц—Ч",
          "begin": "(\\w+)\\(",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.ccil"
            }
          },
          "end": "\\)"
        }
      ]
    },
    "construct": {
      "patterns": [
        {
          "comment": "—Б—В–≤–Њ—А–µ–љ–љ—П —Б—В—А—Г–Ї—В—Г—А–Є",
          "begin": "(\\w+){",
          "beginCaptures": {
            "1": {
              "name": "entity.name.class.ccil"
            }
          },
          "end": "}"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "comment": "–Ј–Љ—Ц–љ–љ–∞",
          "name": "variable.other.ccil",
          "match": "\\b(\\w+'?\\w+)\\b"
        }
      ]
    }
  },
  "scopeName": "source.—Ж—Ц–ї—М"
}
