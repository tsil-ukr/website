{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "–¶—Ц–ї—М",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#construct"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ccil",
          "match": "\\b(–і—Ц—П|–µ–Ї—Б—В–µ—А–љ|—Ж—Ц–ї—М|–Љ–µ—В–∞|–≤–Є–і–∞–ї–Є—В–Є|–Ј–Љ—Ц–љ–љ–∞|–Ї–Њ–Љ–њ–Њ–Ј–Є—Ж—Ц—П|—Б–µ–Ї—Ж—Ц—П|–≤–ї–∞—Б—В–Є–≤—Ц—Б—В—М|—Б–њ–µ—Ж|—П|—А–Њ–Ј—И–Є—А–Є—В–Є|–Ј–Њ–≤–љ—Ц—И–љ—П|–≤–љ—Г—В—А—Ц—И–љ—П|–њ–Њ–Ї–ї–∞—Б—В–Є|–≤—Ц–і–Ї–ї–∞—Б—В–Є|—Б—В—А—Г–Ї—В—Г—А–∞|–њ–µ—А–µ–±—А–∞—В–Є|—П–Ї—Й–Њ|—З–µ–Ї–∞—В–Є|–≤–Ј—П—В–Є|–≤–µ—А–љ—Г—В–Є|—Ц–љ–∞–Ї—И–µ|–±—Ц–±|–њ–Њ–Ї–Є)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ccil",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ccil",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.ccil",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.ccil",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ccil",
          "begin": "/\\*.*",
          "end": "\\*/"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.ccil",
          "match": "\\b(—В–µ–Ї—Б—В|–њ–∞–Љ Љ—П—В—М|–Ї–Њ–Љ—Ц—А–Ї–∞|–ї–Њ–≥—Ц—З–љ–µ|—Ж8|—Ж16|—Ж32|—Ж—Ц–ї–µ|–і32|–і—Ц–є—Б–љ–µ|–њ8|–њ16|–њ32|–њ–Њ–Ј–Є—В–Є–≤–љ–µ|—Б–њ–Є—Б–Њ–Ї|—Й–Њ—Б—М|–љ—Ц—Й–Њ|—В–∞–Ї|–љ—Ц|–њ—Г—Б—В–Њ)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "comment": "–Ј–Љ—Ц–љ–љ–∞",
          "name": "variable.other.ccil",
          "match": "\\b(\\w+'?\\w+)\\b"
        }
      ]
    }
  },
  "scopeName": "source.—Ж—Ц–ї—М"
}
